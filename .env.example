#!/ Frontend Environment Variables #!/

# API Configuration
VITE_API_URL=http://localhost:3000

# Blockchain Configuration (Optional)
# Default: Stellar Soroban Testnet
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Smart Contract ID (Required for blockchain storage)
# Get this after deploying the contract:
# 1. Deploy to testnet: soroban contract deploy ...
# 2. Copy contract ID (starts with CDATA...)
# 3. Paste here
# 4. Restart dev server
# NOTE: If not set, blockchain storage gracefully skips
VITE_CONTRACT_ID=your_deployed_contract_id_here

# Backend Configuration
VITE_ADMIN_EMAIL=bhaleraonishit@gmail.com
VITE_ADMIN_PASSWORD=nishit@stellarguard2026 

